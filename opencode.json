{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".agent/README.md",
    "AGENTS.md",
    "CLAUDE.md",
    ".agent/templates/tc-template.md",
    ".agent/templates/implementation-plan-template.md",
    ".agent/templates/summary-template.md",
    ".agent/templates/*-dispatch.md",
    "docs/constitution/001-pom-architecture.md",
    "docs/constitution/002-coding-standards.md",
    "docs/constitution/003-anti-hallucination.md",
    "docs/constitution/004-quality-gate.md",
    "docs/constitution/005-design-patterns.md",
    "docs/workflows/000-triage.md",
    "docs/workflows/001-test-task-sop.md",
    "docs/workflows/002-multi-agent-orchestration.md",
    "docs/workflows/003-bugfix-sop.md",
    "docs/personas/orchestrator-lead.md",
    "docs/personas/researcher.md",
    "docs/personas/builder.md",
    "docs/personas/reflector.md",
    "docs/personas/qa-gatekeeper.md",
    "docs/personas/reviewer.md",
    "skills/memory-management/SKILL.md"
  ],
  "default_agent": "build",
  "agent": {
    "lead": {
      "description": "Orchestrates multi-agent workflow: plans, delegates, summarizes",
      "mode": "primary",
      "prompt": "{file:.opencode/agents/lead.md}",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git log*": "allow",
          "ls *": "allow",
          "npx playwright test*": "allow"
        },
        "task": {
          "*": "deny",
          "researcher": "allow",
          "builder": "allow",
          "reflector": "allow",
          "qa-gatekeeper": "allow"
        },
        "todowrite": "allow"
      }
    },
    "researcher": {
      "description": "Read-only UI/UX code explorer for routes, components, selectors, validation rules",
      "mode": "subagent",
      "prompt": "{file:.opencode/agents/researcher.md}",
      "permission": {
        "read": "allow",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "ls *": "allow",
          "git diff*": "allow",
          "git log*": "allow"
        },
        "task": "deny",
        "todowrite": "deny"
      }
    },
    "builder": {
      "description": "Implements POM files, spec files, and test data factories",
      "mode": "subagent",
      "prompt": "{file:.opencode/agents/builder.md}",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "ls *": "allow",
          "npm *": "allow",
          "npx *": "allow"
        },
        "task": "deny",
        "todowrite": "allow"
      }
    },
    "reflector": {
      "description": "Self-critique agent: reviews builder output before QA",
      "mode": "subagent",
      "prompt": "{file:.opencode/agents/reflector.md}",
      "permission": {
        "read": "allow",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "bash": "deny",
        "task": "deny",
        "todowrite": "deny"
      }
    },
    "qa-gatekeeper": {
      "description": "Runs Playwright tests and decides pass/block verdict",
      "mode": "subagent",
      "prompt": "{file:.opencode/agents/qa-gatekeeper.md}",
      "permission": {
        "read": "allow",
        "edit": {
          ".agent/tasks/*": "allow",
          "*": "deny"
        },
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "npx playwright test*": "allow",
          "ls *": "allow"
        },
        "task": "deny",
        "todowrite": "deny"
      }
    }
  },
  "command": {
    "test-feature": {
      "template": "Run Playwright tests for a specific feature. Read the feature's spec files from src/tests/specs/{feature}/ and run npx playwright test --grep {feature} --reporter=list. Report pass/fail counts and any errors.",
      "description": "Run tests for a specific feature",
      "agent": "lead"
    },
    "plan-feature": {
      "template": "Create a test plan for feature {feature}. Read docs/workflows/001-test-task-sop.md, then read the app source at ../groapp-access/src/features/{feature}/ and existing tests. Write .agent/plans/implementation-plan-{feature}.md and per-TC todo files .agent/plans/todos/tc-*.md with ownership assigned.",
      "description": "Create test plan for a feature",
      "agent": "lead"
    },
    "dispatch-researchers": {
      "template": "Dispatch the 4 researcher sub-agents (routes, components, validators, pom-patterns) to explore feature {feature}. Provide the implementation plan path .agent/plans/implementation-plan-{feature}.md and assigned per-TC todo files.",
      "description": "Dispatch parallel researchers for a feature",
      "agent": "lead"
    }
  },
  "permission": {
    "edit": "ask",
    "bash": "ask"
  },
  "mcp": {
    "memory": {
      "type": "local",
      "enabled": true
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      "test-results/**",
      "playwright-report/**"
    ]
  }
}
