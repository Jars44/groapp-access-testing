{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".agent/README.md",
    "AGENTS.md",
    "CLAUDE.md",
    ".agent/templates/tc-template.md",
    ".agent/templates/implementation-plan-template.md",
    ".agent/templates/summary-template.md",
    ".agent/templates/*-dispatch.md",
    "docs/constitution/001-pom-architecture.md",
    "docs/constitution/002-coding-standards.md",
    "docs/constitution/003-anti-hallucination.md",
    "docs/constitution/004-quality-gate.md",
    "docs/constitution/005-design-patterns.md",
    "docs/workflows/000-triage.md",
    "docs/workflows/001-test-task-sop.md",
    "docs/workflows/002-multi-agent-orchestration.md",
    "docs/workflows/003-bugfix-sop.md",
    "docs/personas/orchestrator-lead.md",
    "docs/personas/researcher.md",
    "docs/personas/builder.md",
    "docs/personas/reflector.md",
    "docs/personas/qa-gatekeeper.md",
    "docs/personas/reviewer.md",
    "skills/memory-management/SKILL.md"
  ],
  "default_agent": "build",
  "agent": {
    "lead": {
      "description": "Orchestrates multi-agent workflow: plans, delegates, summarizes",
      "mode": "primary",
      "prompt": "{file:.opencode/agents/lead.md}",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git log*": "allow",
          "ls *": "allow",
          ".agent/hooks/test.sh*": "allow"
        },
        "task": {
          "*": "deny",
          "researcher": "allow",
          "builder": "allow",
          "reflector": "allow",
          "qa-gatekeeper": "allow"
        },
        "todowrite": "allow"
      }
    },
    "researcher": {
      "description": "Read-only UI/UX code explorer for routes, components, selectors, validation rules",
      "mode": "subagent",
      "prompt": "{file:.opencode/agents/researcher.md}",
      "permission": {
        "read": "allow",
        "edit": {
          ".agent/tasks/researcher-*": "allow",
          ".agent/plans/todos/tc-*": "allow",
          ".agent/memory/entities/*.json": "allow",
          "*": "deny"
        },
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "ls *": "allow",
          "git diff*": "allow",
          "git log*": "allow"
        },
        "task": "deny",
        "todowrite": "allow"
      }
    },
    "builder": {
      "description": "Implements POM files, spec files, and test data factories",
      "mode": "subagent",
      "prompt": "{file:.opencode/agents/builder.md}",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "ls *": "allow",
          "npm *": "allow",
          "npx *": "allow"
        },
        "task": "deny",
        "todowrite": "allow"
      }
    },
    "reflector": {
      "description": "Self-critique agent: reviews builder output before QA",
      "mode": "subagent",
      "prompt": "{file:.opencode/agents/reflector.md}",
      "permission": {
        "read": "allow",
        "edit": {
          ".agent/tasks/reflector-*": "allow",
          ".agent/memory/entities/*.json": "allow",
          "*": "deny"
        },
        "glob": "allow",
        "grep": "allow",
        "bash": "deny",
        "task": "deny",
        "todowrite": "deny"
      }
    },
    "qa-gatekeeper": {
      "description": "Runs Playwright tests and decides pass/block verdict",
      "mode": "subagent",
      "prompt": "{file:.opencode/agents/qa-gatekeeper.md}",
      "permission": {
        "read": "allow",
        "edit": {
          ".agent/tasks/*": "allow",
          "*": "deny"
        },
        "glob": "allow",
        "grep": "allow",
        "bash": {
          ".agent/hooks/test.sh*": "allow",
          "ls *": "allow"
        },
        "task": "deny",
        "todowrite": "deny"
      }
    }
  },
  "command": {
    "triage": {
      "description": "Phase 0: Classify request, route to hotfix/mode-c/epic",
      "agent": "lead",
      "template": ".opencode/commands/triage.md"
    },
    "hotfix": {
      "description": "Level 1: Fast-track single file fix (< 3 TCs)",
      "agent": "lead",
      "template": ".opencode/commands/hotfix.md"
    },
    "mode-c": {
      "description": "Level 2: Full Mode C pipeline (3-50 TCs)",
      "agent": "lead",
      "template": ".opencode/commands/mode-c.md"
    },
    "researcher-a": {
      "description": "Researcher A: Routes & navigation discovery",
      "agent": "researcher",
      "template": ".opencode/commands/researcher-a.md"
    },
    "researcher-b": {
      "description": "Researcher B: Components & selectors discovery",
      "agent": "researcher",
      "template": ".opencode/commands/researcher-b.md"
    },
    "researcher-c": {
      "description": "Researcher C: Validators & error states discovery",
      "agent": "researcher",
      "template": ".opencode/commands/researcher-c.md"
    },
    "researcher-d": {
      "description": "Researcher D: Existing POM patterns discovery",
      "agent": "researcher",
      "template": ".opencode/commands/researcher-d.md"
    },
    "builder-pom": {
      "description": "Builder POM: Create/update Page Object Model files",
      "agent": "builder",
      "template": ".opencode/commands/builder-pom.md"
    },
    "builder-spec": {
      "description": "Builder Specs: Create/update Playwright test specs",
      "agent": "builder",
      "template": ".opencode/commands/builder-spec.md"
    },
    "reflector-pom": {
      "description": "Reflector POM: Critique POM structure",
      "agent": "reflector",
      "template": ".opencode/commands/reflector-pom.md"
    },
    "reflector-spec": {
      "description": "Reflector Spec: Critique spec quality",
      "agent": "reflector",
      "template": ".opencode/commands/reflector-spec.md"
    },
    "qa-gatekeeper": {
      "description": "QA Gatekeeper: Run tests, decide pass/block verdict",
      "agent": "qa-gatekeeper",
      "template": ".opencode/commands/qa-gatekeeper.md"
    },
    "review": {
      "description": "Reviewer: Full audit (Stage 1 compliance + Stage 2 quality)",
      "agent": "reviewer",
      "template": ".opencode/commands/review.md"
    }
  },
  "permission": {
    "edit": "ask",
    "bash": "ask"
  },
  "mcp": {
    "memory": {
      "type": "local",
      "enabled": true
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      "test-results/**",
      "playwright-report/**"
    ]
  }
}
