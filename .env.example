# GroApp Access — E2E Test Environment
# Copy to .env and fill in values.
# .env is git-ignored — secrets stay local.

# Path to app source code (resolved from project root)
# Default: ../groapp-access
GROAPP_ACCESS_SOURCE_DIR=../groapp-access

# Test user credentials — used by auth data factories
TEST_USER_EMAIL=your_test_email
TEST_USER_PASSWORD=your_test_password

# CI mode (set by CI runner automatically)
# CI=true  — enables retries, single worker, disables server reuse
