      "human_gate": { "agents": ["lead", "user"], "parallel": false, "depends_on": "planning" },
      "implementation": { "agents": ["builder-pom", "builder-spec", "lead"], "parallel": true, "depends_on": "human_gate" },
      "reflection_pom": { "agents": ["reflector-pom"], "parallel": false, "depends_on": "implementation" },
      "reflection_spec": { "agents": ["reflector-spec"], "parallel": false, "depends_on": "reflection_pom" },
      "verification": { "agents": ["qa-gatekeeper", "lead"], "parallel": true, "depends_on": "reflection_spec" },
