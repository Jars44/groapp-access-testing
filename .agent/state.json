{
  "version": "2.2.0",
  "description": "Pipeline state machine — Mode C multi-agent orchestration. Tracks phases, tasks, memory, reflection, and artifact paths across all agents.",
  "metadata": {
    "project": "groapp-access-testing",
    "started_at": null,
    "completed_at": null,
    "last_updated": null,
    "sourceDir": "../groapp-access",
    "config_files": {
      "opencode": "opencode.json",
      "claude": ".claude/settings.json",
      "antigravity": "antigravity.json",
      "agents": ".opencode/agents/",
      "templates_dir": ".agent/templates/"
    }
  },
  "pipeline": {
    "mode": "mode-c",
    "phase": "idle",
    "status": "idle",
    "attempt": 0,
    "max_attempts": 3,
    "phases": {
      "discovery": { "agents": ["lead", "researcher-routes", "researcher-components", "researcher-pom-patterns", "researcher-validators"], "parallel": true },
      "implementation": { "agents": ["builder", "lead"], "parallel": false, "depends_on": "discovery" },
      "reflection": { "agents": ["reflector"], "parallel": false, "depends_on": "implementation", "max_cycles": 3 },
      "verification": { "agents": ["qa-gatekeeper", "lead"], "parallel": true, "depends_on": "reflection" },
      "teardown": { "agents": ["lead"], "parallel": false, "depends_on": "verification" }
    }
  },
  "errors": [],
  "tasks": [],
  "todos": {
    "dir": ".agent/plans/todos/",
    "template": ".agent/templates/tc-template.md",
    "count": 0,
    "files": []
  },
  "artifacts": {
    "implementation_plan": null,
    "research_findings": [],
    "pom_files": [],
    "spec_files": [],
    "data_factories": [],
    "fixtures": [],
    "reports": [],
    "summary": null,
    "per_agent_outputs": []
  },
  "summary": {
    "generated_at": null,
    "total_todos": 0,
    "passed": 0,
    "blocked": 0,
    "skipped": 0,
    "gaps": [],
    "summary_path": "",
    "template": ".agent/templates/summary-template.md"
  },
  "memory_state": {
    "entities_dir": ".agent/memory/entities/",
    "schema_file": ".agent/memory/schema.md",
    "entities_count": 0,
    "relations_count": 0,
    "last_persisted": null,
    "strategy": "per-entity-files",
    "ownership": {
      "lead": ["relation_creation", "schema_validation"],
      "researcher": ["component-selector", "route", "pom-pattern", "validation-rule"],
      "builder": ["observation_updates"],
      "reflector": ["critique_annotations"],
      "qa-gatekeeper": ["test_result_annotations"],
      "reviewer": ["audit_findings"]
    }
  },
  "reflection_cycle": {
    "enabled": true,
    "max_full_cycles": 3,
    "current_full_cycle": 0,
    "sub_cycles": ["pom", "spec"],
    "current_sub_cycle": null,
    "overall_verdict": "not_started",
    "reflector_task_files": {
      "pom": null,
      "spec": null
    },
    "cycles": []
  },
  "conflict_prevention": {
    "todos_strategy": "per-tc-files",
    "memory_strategy": "per-entity-files",
    "merge_points": ["research_aggregation", "teardown"],
    "ownership_enforced": true,
    "single_writers": {
      "state.json": "lead",
      "summary": "lead",
      "relations.json": "lead"
    },
    "per_agent_writers": {
      "plans/todos/": "assigned agent per TC",
      "memory/entities/": "creator + annotators",
      "tasks/": "one agent per file"
    }
  },
  "discovery_map": {
    "non_agent_dirs": {
      ".agent/plans/": "Temporary test plans + per-TC todos",
      ".agent/reports/": "Permanent summaries",
      ".agent/templates/": "Dispatch prompts + templates",
      ".agent/hooks/": "Pre/post validation scripts"
    },
    "skills": [
      "skills/memory-management/SKILL.md",
      "skills/dispatching-e2e-tests/SKILL.md",
      "skills/auditing-selector-quality/SKILL.md"
    ],
    "configs": [
      "opencode.json",
      ".claude/settings.json",
      "antigravity.json",
      "AGENTS.md",
      "CLAUDE.md"
    ]
  },
  "validation": {
    "last_preflight": null,
    "last_handoff_validation": null,
    "preflight_ok": false
  },
  "schema": {
    "version": "2.2.0",
    "tasks": [
      {
        "id": "TC-001",
        "description": "short description",
        "scenario_type": "happy path | error | edge case | validation",
        "priority": "P0 | P1 | P2 | P3",
        "route": "target URL",
        "test_data_ref": "factory function or constant path",
        "selectors": ["list of selectors used"],
        "expected": "expected outcome for human to verify",
        "status": "not_started | in_progress | implemented | passed | blocked | skipped",
        "tc_file": ".agent/plans/todos/tc-{id}.md",
        "evidence": {
          "spec_file": "path to spec file",
          "spec_line": "line number of test",
          "pom_file": "path to POM file",
          "pom_line": "line number of selector/action",
          "data_file": "path to data factory",
          "test_run_result": "pass | fail | flaky | not_run",
          "verification_notes": "human-readable notes for reviewer"
        },
        "owner": {
          "discovery": "researcher-{domain}",
          "implementation": "builder",
          "reflection": "reflector",
          "verification": "qa-gatekeeper"
        },
        "status_history": [
          {
            "timestamp": "ISO 8601",
            "agent": "agent name",
            "status": "[ ] | [/] | [x] | [-]",
            "notes": "what changed"
          }
        ]
      }
    ],
    "errors": [
      {
        "phase": "string",
        "agent": "string",
        "code": "string — error taxonomy",
        "message": "string",
        "evidence": "string — file:line or test output",
        "recovery": "retry | skip | block",
        "timestamp": "ISO 8601"
      }
    ],
    "error_taxonomy": {
      "E001": "state_unreadable",
      "E002": "handoff_invalid",
      "E003": "source_dir_missing",
      "E004": "test_run_failed",
      "E005": "flaky_test",
      "E006": "quality_block",
      "E007": "artifact_missing",
      "E008": "timeout",
      "E009": "tool_restricted",
      "E010": "pipeline_blocked",
      "E011": "memory_write_conflict",
      "E012": "reflection_max_cycles_exceeded",
      "E013": "todo_evidence_missing",
      "E014": "per_agent_output_missing"
    },
    "handoff_protocol": {
      "lead_to_researchers": { "required": ["pipeline.phase", "artifacts.implementation_plan"], "phase": "discovery" },
      "researchers_to_builders": { "required": ["artifacts.research_findings"], "phase": "exploration" },
      "halt_to_user": { "required": ["artifacts.implementation_plan", "todos.count"], "phase": "planning_complete" },
      "builders_to_reflector": { "required": ["artifacts.pom_files", "artifacts.spec_files"], "phase": "implementation" },
      "reflector_pom_to_spec": { "required": ["reflection_cycle.pom_verdict"], "verdict": "pass", "phase": "reflection_pom" },
      "reflector_to_gatekeeper": { "required": ["reflection_cycle.overall_verdict"], "verdict": "pass", "phase": "reflection" },
      "gatekeeper_to_lead": { "required": ["artifacts.reports"], "phase": "verification" }
    },
    "parallel_phases": {
      "discovery": {
        "agents": ["lead", "researcher-routes", "researcher-components", "researcher-pom-patterns", "researcher-validators"],
        "writes": [".agent/plans/todos/tc-*.md", ".agent/memory/entities/*.json"]
      },
      "implementation": {
        "agents": ["builder-pom", "builder-spec", "lead"],
        "parallel": true,
        "writes": ["src/tests/pages/**/*.page.ts", "src/tests/components/**/*.component.ts", "src/tests/specs/**/*.spec.ts", ".agent/plans/todos/tc-*.md", ".agent/memory/entities/*.json"]
      },
      "reflection_pom": {
        "agents": ["reflector-pom"],
        "parallel": false,
        "writes": [".agent/tasks/reflector-{ts}.json", ".agent/memory/entities/*.json"]
      },
      "reflection_spec": {
        "agents": ["reflector-spec"],
        "parallel": false,
        "depends_on": "reflection_pom",
        "writes": [".agent/tasks/reflector-{ts}.json", ".agent/memory/entities/*.json"]
      },
      "verification": {
        "agents": ["qa-gatekeeper", "lead", "reflector-pom", "reflector-spec"],
        "parallel": true,
        "writes": [".agent/tasks/qa-gatekeeper-{ts}.json", ".agent/reports/summary-{feature}.md", ".agent/memory/entities/*.json"]
      },
      "teardown": {
        "agents": ["lead"],
        "parallel": false,
        "writes": [".agent/state.json", ".agent/memory/entities/relations.json", ".agent/reports/summary-{feature}.md"]
      }
    }
  }
}
