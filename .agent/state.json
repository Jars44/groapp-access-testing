    "last_persisted": null,
    "strategy": "per-entity-files",
    "ownership": {
      "lead": ["relation_creation", "schema_validation"],
      "researcher-A": ["route"],
      "researcher-B": ["component-selector"],
      "researcher-C": ["validation-rule"],
      "researcher-D": ["pom-pattern"],
      "builder-pom": ["observation_updates"],
