  "conflict_prevention": {
    "todos_strategy": "per-tc-files",
    "memory_strategy": "per-entity-files",
    "merge_points": ["research_aggregation", "teardown"],
    "ownership_enforced": true,
    "single_writers": {
      "state.json": "lead",
      "summary": "lead",
      "relations.json": "lead"
    },
    "per_agent_writers": {
      "plans/todos/": "assigned agent per TC",
      "memory/entities/": "creator + annotators",
      "tasks/": "one agent per file"
    }
  },
  "commands": {
    "orchestrator": ["triage", "hotfix", "mode-c"],
    "researcher": ["researcher-a", "researcher-b", "researcher-c", "researcher-d"],
    "builder": ["builder-pom", "builder-spec"],
    "reflector": ["reflector-pom", "reflector-spec"],
    "qa": ["qa-gatekeeper"],
    "review": ["review"],
    "total": 13
  },
  "discovery_map": {
    "non_agent_dirs": {
      ".agent/plans/": "Temporary test plans + per-TC todos",
      ".agent/reports/": "Permanent summaries",
      ".agent/templates/": "Dispatch prompts + templates",
      ".agent/hooks/": "Pre/post validation scripts"
    },
    "skills": [
      "skills/memory-management/SKILL.md",
      "skills/dispatching-e2e-tests/SKILL.md",
      "skills/auditing-selector-quality/SKILL.md"
    ],
    "configs": [
      "opencode.json",
      ".claude/settings.json",
      "antigravity.json",
      "AGENTS.md",
      "CLAUDE.md"
    ]
  },
  "validation": {
    "last_preflight": null,
    "last_handoff_validation": null,
    "preflight_ok": false
  },
  "schema": {
    "version": "2.3.0",
    "triage": {
      "level": "hotfix | standard | epic",
      "level_name": "string",
      "tc_estimate": "number",
      "routed_to": "string — workflow name",
      "timestamp": "ISO 8601"
    },
    "tasks": [
      {
        "id": "TC-001",
        "description": "short description",
        "scenario_type": "happy path | error | edge case | validation",
        "priority": "P0 | P1 | P2 | P3",
        "route": "target URL",
        "test_data_ref": "factory function or constant path",
        "selectors": ["list of selectors used"],
        "expected": "expected outcome for human to verify",
        "status": "not_started | in_progress | implemented | passed | blocked | skipped",
        "tc_file": ".agent/plans/todos/tc-{id}.md",
        "evidence": {
          "spec_file": "path to spec file",
          "spec_line": "line number of test",
          "pom_file": "path to POM file",
          "pom_line": "line number of selector/action",
          "data_file": "path to data factory",
          "test_run_result": "pass | fail | flaky | not_run",
          "verification_notes": "human-readable notes for reviewer"
        },
        "owner": {
          "discovery": "researcher-{A|B|C|D}",
          "implementation": "builder-pom | builder-spec",
          "reflection": "reflector-pom | reflector-spec",
          "verification": "qa-gatekeeper"
        },
        "status_history": [
          {
            "timestamp": "ISO 8601",
            "agent": "agent name",
            "status": "[ ] | [/] | [x] | [-]",
            "notes": "what changed"
          }
        ]
      }
    ],
    "errors": [
      {
        "phase": "string",
        "agent": "string",
        "code": "string — error taxonomy",
        "message": "string",
        "evidence": "string — file:line or test output",
        "recovery": "retry | skip | block",
        "timestamp": "ISO 8601"
      }
    ],
    "error_taxonomy": {
      "E001": "state_unreadable",
      "E002": "handoff_invalid",
      "E003": "source_dir_missing",
      "E004": "test_run_failed",
      "E005": "flaky_test",
      "E006": "quality_block",
      "E007": "artifact_missing",
      "E008": "timeout",
      "E009": "tool_restricted",
      "E010": "pipeline_blocked",
      "E011": "memory_write_conflict",
      "E012": "reflection_max_cycles_exceeded",
      "E013": "todo_evidence_missing",
      "E014": "per_agent_output_missing",
      "E015": "triage_level_ambiguous",
      "E016": "hotfix_scope_exceeded"
    },
    "handoff_protocol": {
      "triage_to_hotfix": { "required": ["triage.level"], "level": "hotfix", "phase": "triage" },
      "triage_to_mode_c": { "required": ["triage.level"], "level": "standard", "phase": "triage" },
      "triage_to_epic": { "required": ["triage.level"], "level": "epic", "phase": "triage", "action": "defer" },
      "lead_to_researchers": { "required": ["pipeline.phase", "triage.level"], "phase": "research" },
      "researchers_to_builders": { "required": ["artifacts.research_findings"], "phase": "human_gate" },
      "halt_to_user": { "required": ["artifacts.implementation_plan", "todos.count"], "phase": "planning_complete" },
      "builders_to_reflector": { "required": ["artifacts.pom_files", "artifacts.spec_files"], "phase": "implementation" },
      "reflector_pom_to_spec": { "required": ["reflection_cycle.pom_verdict"], "verdict": "pass", "phase": "reflection_pom" },
      "reflector_to_gatekeeper": { "required": ["reflection_cycle.overall_verdict"], "verdict": "pass", "phase": "reflection" },
      "gatekeeper_to_lead": { "required": ["artifacts.reports"], "phase": "verification" }
    },
    "timestamps": {
      "human_readable": "dd-mm-yyyy:hh:mm",
      "machine_filenames": "YYYYMMDDHHMMSS",
      "json_metadata": "ISO 8601"
    },
    "parallel_phases": {
      "triage": {
        "agents": ["lead"],
        "parallel": false,
        "writes": [".agent/state.json"]
      },
      "research": {
        "agents": ["researcher-A", "researcher-B", "researcher-C", "researcher-D"],
        "parallel": true,
        "writes": [".agent/memory/entities/*.json", ".agent/tasks/researcher-{variant}-{YYYYMMDDHHMMSS}-{seq}.json"]
      },
      "planning": {
        "agents": ["lead"],
        "parallel": false,
        "depends_on": "research",
        "writes": [".agent/plans/implementation-plan-{feature}.md", ".agent/plans/todos/tc-*.md"]
      },
      "human_gate": {
        "agents": ["lead", "user"],
        "parallel": false,
        "depends_on": "planning",
        "writes": []
      },
      "implementation": {
        "agents": ["builder-pom", "builder-spec", "lead"],
        "parallel": true,
        "writes": ["src/tests/pages/**/*.page.ts", "src/tests/components/**/*.component.ts", "src/tests/specs/**/*.spec.ts", ".agent/plans/todos/tc-*.md", ".agent/memory/entities/*.json", ".agent/tasks/builder-{pom|spec}-{YYYYMMDDHHMMSS}-{seq}.json"]
      },
      "reflection_pom": {
        "agents": ["reflector-pom"],
        "parallel": false,
        "depends_on": "implementation",
        "writes": [".agent/tasks/reflector-{ts}.json", ".agent/memory/entities/*.json"]
      },
      "reflection_spec": {
        "agents": ["reflector-spec"],
        "parallel": false,
        "depends_on": "reflection_pom",
        "writes": [".agent/tasks/reflector-{ts}.json", ".agent/memory/entities/*.json"]
      },
      "verification": {
        "agents": ["qa-gatekeeper", "lead"],
        "parallel": true,
        "depends_on": "reflection_spec",
        "writes": [".agent/tasks/qa-gatekeeper-{ts}.json", ".agent/reports/summary-{feature}.md", ".agent/memory/entities/*.json"]
      },
      "teardown": {
        "agents": ["lead"],
        "parallel": false,
        "depends_on": "verification",
        "writes": [".agent/state.json", ".agent/memory/entities/relations.json", ".agent/reports/summary-{feature}.md"]
      }
    },
    "hotfix": {
      "skip_phases": ["research", "planning", "human_gate", "reflection_pom", "reflection_spec"],
      "required_phases": ["triage", "implementation", "verification", "teardown"],
      "max_tcs": 3,
      "output_format": "brief_status_message"
    }
  }
}